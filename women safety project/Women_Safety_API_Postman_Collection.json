{
  "info": {
    "name": "Women Safety API",
    "description": "Complete API collection for Women Safety Backend - Emergency alert system",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5002/api",
      "type": "string"
    },
    {
      "key": "user_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "contact_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "alert_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            },
            "description": "Check if the backend server is running"
          }
        },
        {
          "name": "API Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/status",
              "host": ["{{base_url}}"],
              "path": ["status"]
            },
            "description": "Get API operational status and version"
          }
        }
      ]
    },
    {
      "name": "User Management",
      "item": [
        {
          "name": "Guest Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{base_url}}/users/guest-login",
              "host": ["{{base_url}}"],
              "path": ["users", "guest-login"]
            },
            "description": "Create temporary guest user session",
            "event": [
              {
                "listen": "test",
                "script": {
                  "exec": [
                    "if (pm.response.code === 200) {",
                    "    const response = pm.response.json();",
                    "    pm.collectionVariables.set('user_id', response.user.id);",
                    "    console.log('Guest user ID set:', response.user.id);",
                    "}"
                  ]
                }
              }
            ]
          }
        },
        {
          "name": "User Signup",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"name\": \"Test User\",\n  \"phone\": \"+91 9876543210\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/users/signup",
              "host": ["{{base_url}}"],
              "path": ["users", "signup"]
            },
            "description": "Register new user with email and phone",
            "event": [
              {
                "listen": "test",
                "script": {
                  "exec": [
                    "if (pm.response.code === 201) {",
                    "    const response = pm.response.json();",
                    "    pm.collectionVariables.set('user_id', response.user.id);",
                    "    console.log('User ID set:', response.user.id);",
                    "}"
                  ]
                }
              }
            ]
          }
        },
        {
          "name": "User Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/users/login",
              "host": ["{{base_url}}"],
              "path": ["users", "login"]
            },
            "description": "Login with registered email",
            "event": [
              {
                "listen": "test",
                "script": {
                  "exec": [
                    "if (pm.response.code === 200) {",
                    "    const response = pm.response.json();",
                    "    pm.collectionVariables.set('user_id', response.user.id);",
                    "    console.log('User ID set:', response.user.id);",
                    "}"
                  ]
                }
              }
            ]
          }
        },
        {
          "name": "Get User Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-user-id",
                "value": "{{user_id}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/users/profile",
              "host": ["{{base_url}}"],
              "path": ["users", "profile"]
            },
            "description": "Retrieve current logged-in user's profile"
          }
        },
        {
          "name": "Update User Profile",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "x-user-id",
                "value": "{{user_id}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Test User\",\n  \"phone\": \"+91 9876543211\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/users/profile",
              "host": ["{{base_url}}"],
              "path": ["users", "profile"]
            },
            "description": "Update name and phone number"
          }
        }
      ]
    },
    {
      "name": "Trusted Contacts",
      "item": [
        {
          "name": "Add Contact",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-user-id",
                "value": "{{user_id}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Mom\",\n  \"phone\": \"+91 9876543212\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/contacts",
              "host": ["{{base_url}}"],
              "path": ["contacts"]
            },
            "description": "Add a new trusted contact",
            "event": [
              {
                "listen": "test",
                "script": {
                  "exec": [
                    "if (pm.response.code === 201) {",
                    "    const response = pm.response.json();",
                    "    pm.collectionVariables.set('contact_id', response.contact.id);",
                    "    console.log('Contact ID set:', response.contact.id);",
                    "}"
                  ]
                }
              }
            ]
          }
        },
        {
          "name": "Get All Contacts",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-user-id",
                "value": "{{user_id}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/contacts",
              "host": ["{{base_url}}"],
              "path": ["contacts"]
            },
            "description": "Retrieve all trusted contacts for user"
          }
        },
        {
          "name": "Update Contact",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "x-user-id",
                "value": "{{user_id}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Mother\",\n  \"phone\": \"+91 9876543213\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/contacts/{{contact_id}}",
              "host": ["{{base_url}}"],
              "path": ["contacts", "{{contact_id}}"]
            },
            "description": "Update contact information"
          }
        },
        {
          "name": "Delete Contact",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "x-user-id",
                "value": "{{user_id}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/contacts/{{contact_id}}",
              "host": ["{{base_url}}"],
              "path": ["contacts", "{{contact_id}}"]
            },
            "description": "Remove a trusted contact"
          }
        }
      ]
    },
    {
      "name": "SOS Alerts",
      "item": [
        {
          "name": "Trigger SOS Alert",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-user-id",
                "value": "{{user_id}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"latitude\": 28.7041,\n  \"longitude\": 77.1025,\n  \"message\": \"Emergency! Help needed!\",\n  \"notificationMethod\": \"both\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/sos/trigger",
              "host": ["{{base_url}}"],
              "path": ["sos", "trigger"]
            },
            "description": "Send emergency alert to all trusted contacts",
            "event": [
              {
                "listen": "test",
                "script": {
                  "exec": [
                    "if (pm.response.code === 200) {",
                    "    const response = pm.response.json();",
                    "    pm.collectionVariables.set('alert_id', response.alert.id);",
                    "    console.log('Alert ID set:', response.alert.id);",
                    "}"
                  ]
                }
              }
            ]
          }
        },
        {
          "name": "Get Alert History",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-user-id",
                "value": "{{user_id}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/sos/alerts?limit=50",
              "host": ["{{base_url}}"],
              "path": ["sos", "alerts"],
              "query": [
                {
                  "key": "limit",
                  "value": "50"
                }
              ]
            },
            "description": "Retrieve all SOS alerts for user"
          }
        },
        {
          "name": "Get Alert Details",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-user-id",
                "value": "{{user_id}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/sos/alerts/{{alert_id}}",
              "host": ["{{base_url}}"],
              "path": ["sos", "alerts", "{{alert_id}}"]
            },
            "description": "Retrieve specific alert information"
          }
        },
        {
          "name": "Resolve Alert",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "x-user-id",
                "value": "{{user_id}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"resolved\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/sos/alerts/{{alert_id}}/resolve",
              "host": ["{{base_url}}"],
              "path": ["sos", "alerts", "{{alert_id}}", "resolve"]
            },
            "description": "Update alert status (resolve or cancel)"
          }
        }
      ]
    }
  ]
}
